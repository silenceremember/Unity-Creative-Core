  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: Narr_IntroMary
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041F\u043E\u043D\u044F\u0442\u043D\u043E."
    duration: 0
    pauseAfter: 0.4
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u042D\u0442\u043E \u041C\u044D\u0440\u0438 \u0421\u043C\u0438\u0442.
      \u0416\u0435\u043D\u0430 \u0414\u0436\u043E\u043D\u0430."
    duration: 0
    pauseAfter: 0.3
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041E\u043D\u0430 \u043D\u0430 \u0431\u0430\u043B\u043A\u043E\u043D\u0435.
      \u0421\u043C\u043E\u0442\u0440\u0438\u0442 \u0432\u0434\u0430\u043B\u044C."
    duration: 0
    pauseAfter: 0.3
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A \u043D\u0435
      \u043F\u0440\u043E\u043F\u0438\u0441\u0430\u043B \u0447\u0442\u043E \u0442\u0430\u043C
      \u0432\u043E \u0434\u0432\u043E\u0440\u0435."
    duration: 0
    pauseAfter: 0.4
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041F\u043E\u044D\u0442\u043E\u043C\u0443 \u0432\u0434\u0430\u043B\u044C
      \u2014 \u044D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u043E HDRI \u043A\u0430\u0440\u0442\u0430."
    duration: 0
    pauseAfter: 0.5
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0425\u043E\u0442\u044F, \u043F\u043E \u043C\u043D\u0435\u043D\u0438\u044E
      \u041C\u044D\u0440\u0438 \u2014 \u043A\u0440\u0430\u0441\u0438\u0432\u0430\u044F
      HDRI \u043A\u0430\u0440\u0442\u0430."
    duration: 0
    pauseAfter: 0.7
    audioClip: {fileID: 0}
  nextSequence: {fileID: 0}
  priority: 0
