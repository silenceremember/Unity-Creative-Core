  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: Narr_Ending
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0414\u0430. \u0427\u0442\u043E-\u0442\u043E \u0435\u0441\u0442\u044C."
    duration: 0
    pauseAfter: 0.4
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0427\u0435\u0441\u0442\u043D\u043E \u0433\u043E\u0432\u043E\u0440\u044F,
      \u044F \u0434\u0443\u043C\u0430\u043B \u044D\u0442\u043E \u0431\u0443\u0434\u0435\u0442
      \u0445\u0443\u0436\u0435."
    duration: 0
    pauseAfter: 0.7
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0445\u043E\u0434\u0438\u0442\u044C
      \u2014 \u044D\u0442\u043E \u0443\u0436\u0435 \u0447\u0442\u043E-\u0442\u043E."
    duration: 0
    pauseAfter: 0.3
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0421\u0438\u043C\u0443\u043B\u044F\u0442\u043E\u0440 \u043A\u0430\u043C\u043D\u044F
      \u0442\u0430\u043A\u043E\u0433\u043E \u043D\u0435 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442."
    duration: 0
    pauseAfter: 0.3
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A \u0441\u0447\u0438\u0442\u0430\u0435\u0442
      \u044D\u0442\u043E \u043F\u043E\u0431\u0435\u0434\u043E\u0439."
    duration: 0
    pauseAfter: 0.3
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u042F \u0441\u043A\u043B\u043E\u043D\u0435\u043D \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u0442\u044C\u0441\u044F."
    duration: 0
    pauseAfter: 0.8
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0423\u0434\u0430\u0447\u0438. \u0418\u043B\u0438 \u043D\u0435\u0442.
      \u041F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u043C."
    duration: 0
    pauseAfter: 1
    audioClip: {fileID: 0}
  nextSequence: {fileID: 0}
  priority: 0
