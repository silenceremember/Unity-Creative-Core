--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 219082fc633aea949a5b932c4ac5e227, type: 3}
  m_Name: NovelSeq_SmithOpening
  m_EditorClassIdentifier: Assembly-CSharp::NovelSequence
  lines:
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u042F \u0441\u0442\u043E\u044E \u0443 \u0434\u0432\u0435\u0440\u0438
      \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E..."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 11400000, guid: 517d1283f39f7d848a5f6faf8cdfe53a, type: 2}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "...\u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043C\u043D\u0435
      \u0437\u0434\u0435\u0441\u044C \u0445\u043E\u0440\u043E\u0448\u043E."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u0421\u043B\u044B\u0448\u0443 \u0441\u043A\u0435\u043F\u0441\u0438\u0441."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 11400000, guid: 1d746b22a2ad0f34786ae1d089df2ecb, type: 2}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u041A\u0440\u0430\u0441\u0438\u0432\u043E \u0437\u0434\u0435\u0441\u044C."
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 11400000, guid: 90712c32ca251184db4aebca25898d5c, type: 2}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u041C\u044D\u0440\u0438."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u0427\u0442\u043E."
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u0412 \u0433\u043E\u0441\u0442\u0438\u043D\u043E\u0439 \u043A\u0442\u043E-\u0442\u043E
      \u0435\u0441\u0442\u044C."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u0422\u044B \u0443\u0432\u0435\u0440\u0435\u043D?"
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u042F... \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E. \u0422\u0430\u043C
      \u043A\u0442\u043E-\u0442\u043E \u0435\u0441\u0442\u044C."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: Player 1
    text: ...
    cameraIndex: 3
    narratorSequenceBefore: {fileID: 11400000, guid: d8dd587f4b1ba064da9c72c0fab34a8b, type: 2}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u041C\u043E\u0436\u0435\u0442, \u044D\u0442\u043E \u043C\u0430\u0441\u0442\u0435\u0440
      \u043F\u043E \u0442\u0435\u043B\u0435\u0432\u0438\u0437\u043E\u0440\u0443?"
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u042F \u043D\u0435 \u0432\u044B\u0437\u044B\u0432\u0430\u043B \u043C\u0430\u0441\u0442\u0435\u0440\u0430."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u042F \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u0430."
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u041A\u043E\u0433\u0434\u0430?"
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u041D\u0435 \u043F\u043E\u043C\u043D\u044E."
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u042D\u0439. \u0422\u044B \u043A\u0442\u043E?"
    cameraIndex: 2
    narratorSequenceBefore: {fileID: 11400000, guid: 2ddee7679b5a49848b01d6076dc38ec6, type: 2}
  - speaker: Player 1
    text: ...
    cameraIndex: 3
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u0422\u044B \u0443\u043C\u0435\u0435\u0448\u044C \u0447\u0438\u043D\u0438\u0442\u044C
      \u0442\u0435\u043B\u0435\u0432\u0438\u0437\u043E\u0440\u044B?"
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 11400000, guid: 2c4de8093a151ac488e3c93605f4039e, type: 2}
  - speaker: Player 1
    text: ...
    cameraIndex: 3
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u044D\u0442\u043E \u0437\u043D\u0430\u043A
      \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u044F."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u0410 \u043A\u0430\u043A \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442?"
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 11400000, guid: d2fc75dfa7c1ccd40b3025eef9e476c9, type: 2}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u042F \u0441\u0442\u043E\u044E."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 11400000, guid: 51a712fc3e49a2a44ac794a2cf133d57, type: 2}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u042F \u0441\u0442\u043E\u044E \u0438 \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u044E."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 11400000, guid: e4362cfbc35eb07478c5e229997a7353, type: 2}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u042F \u043C\u043D\u043E\u0433\u043E\u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u0414\u0436\u043E\u043D."
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u041E\u043D \u0432\u043E\u043E\u0431\u0449\u0435 \u0443\u0439\u0434\u0451\u0442?"
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u041D\u0435 \u0437\u043D\u0430\u044E."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u0414\u0436\u043E\u043D"
    text: "\u0421\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u0442\u044C \u0431\u0435\u0441\u043F\u043E\u043B\u0435\u0437\u043D\u043E,
      \u043E\u043D \u043C\u043E\u043B\u0447\u0438\u0442."
    cameraIndex: 0
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u041F\u043E\u043D\u044F\u0442\u043D\u043E."
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 0}
  - speaker: "\u041C\u044D\u0440\u0438"
    text: "\u041F\u043E\u0434\u043E\u0436\u0434\u0451\u043C \u043F\u043E\u043A\u0430
      \u0441\u0430\u043C \u0440\u0430\u0437\u0431\u0435\u0440\u0451\u0442\u0441\u044F."
    cameraIndex: 1
    narratorSequenceBefore: {fileID: 0}
  - speaker: Player 1
    text: ...
    cameraIndex: 3
    narratorSequenceBefore: {fileID: 11400000, guid: eaa4a09752246524a91504cc4fa17937, type: 2}
