  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: Seq_BrokenPlay
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speaker: Narrator
    text: "\u041E. \u041F\u0440\u0438\u0432\u0435\u0442."
    duration: 0
    pauseAfter: 0.8
    audioClip: {fileID: 0}
  - speaker: Narrator
    text: "\u0422\u044B \u043D\u0430\u0436\u0430\u043B \u0418\u0433\u0440\u0430\u0442\u044C."
    duration: 0
    pauseAfter: 0.6
    audioClip: {fileID: 0}
  - speaker: Narrator
    text: "\u042D\u0442\u043E \u043D\u0435 \u0441\u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442.
      \u0418\u0433\u0440\u0430 \u043D\u0435 \u0437\u0430\u043A\u043E\u043D\u0447\u0435\u043D\u0430."
    duration: 0
    pauseAfter: 0.6
    audioClip: {fileID: 0}
  - speaker: Narrator
    text: "\u0418 \u0432\u0440\u044F\u0434 \u043B\u0438 \u0431\u0443\u0434\u0435\u0442..."
    duration: 0
    pauseAfter: 0.5
    audioClip: {fileID: 0}
  - speaker: Narrator
    text: "\u0425\u043E\u0442\u044F... \u043D\u0435\u0437\u0430\u0432\u0435\u0440\u0448\u0451\u043D\u043D\u043E\u0441\u0442\u044C
      \u043F\u0440\u0438\u0434\u0430\u0451\u0442 \u0448\u0430\u0440\u043C."
    duration: 0
    pauseAfter: 0.5
    audioClip: {fileID: 0}
  - speaker: Narrator
    text: "\u041D\u0430\u0432\u0435\u0440\u043D\u043E\u0435."
    duration: 0
    pauseAfter: 0.8
    audioClip: {fileID: 0}
  - speaker: Narrator
    text: "\u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439 \u043F\u043E\u0438\u0441\u043A\u0430\u0442\u044C
      \u0432 \u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0430\u0445."
    duration: 0
    pauseAfter: 0
    audioClip: {fileID: 0}
  nextSequence: {fileID: 0}
  priority: 1
