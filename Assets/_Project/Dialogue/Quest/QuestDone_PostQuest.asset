  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041F\u043E\u0445\u043E\u0436\u0435, \u0442\u044B \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u043B
