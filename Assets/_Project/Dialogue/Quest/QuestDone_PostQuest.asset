  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0418 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043B 1000 \u043E\u043F\u044B\u0442\u0430."
