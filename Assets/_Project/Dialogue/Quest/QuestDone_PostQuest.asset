    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041E\u0434\u043D\u0430\u043A\u043E."
