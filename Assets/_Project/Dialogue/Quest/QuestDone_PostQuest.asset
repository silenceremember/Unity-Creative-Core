  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041D\u043E \u0442\u0435\u0431\u0435, \u043A\u0430\u0436\u0435\u0442\u0441\u044F,
      \u043D\u0435\u043A\u0443\u0434\u0430 \u0435\u0433\u043E \u0442\u0440\u0430\u0442\u0438\u0442\u044C..."
