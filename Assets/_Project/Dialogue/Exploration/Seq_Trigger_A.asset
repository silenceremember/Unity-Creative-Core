  lines:
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041E. \u0422\u044B \u0437\u0434\u0435\u0441\u044C."
    duration: 0
    pauseAfter: 1.5
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0417\u0434\u0435\u0441\u044C \u0440\u0430\u043D\u044C\u0448\u0435 \u0441\u0442\u043E\u044F\u043B
      \u0442\u043E\u0440\u0448\u0435\u0440."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041C\u044D\u0440\u0438 \u0435\u0433\u043E \u0443\u0431\u0440\u0430\u043B\u0430."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0413\u043E\u0432\u043E\u0440\u0438\u0442 \u2014 \u043C\u0435\u0448\u0430\u043B."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u042F \u043D\u0435 \u0441\u043F\u043E\u0440\u0438\u043B."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041B\u0430\u0434\u043D\u043E. \u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0439."
