    duration: 0
    pauseAfter: 3
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041E\u0431\u044A\u044F\u0441\u043D\u044F\u0442\u044C \u043E\u0447\u0435\u0432\u0438\u0434\u043D\u043E\u0435."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0414\u0430, \u044D\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430."
