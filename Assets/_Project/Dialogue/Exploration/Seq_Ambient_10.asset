  lines:
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041C\u043E\u044F \u0440\u043E\u043B\u044C \u2014 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C,
