  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041F\u0440\u043E\u0441\u0442\u043E \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0448\u044C\u0441\u044F
