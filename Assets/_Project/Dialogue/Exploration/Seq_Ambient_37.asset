  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: Seq_Ambient_37
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0425\u043E\u0442\u044F \u0441 \u0434\u0440\u0443\u0433\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B..."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0427\u0442\u043E \u044D\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442
      \u043E \u043D\u0430\u0441 \u043A\u0430\u043A \u0432\u0438\u0434\u0435?"
    duration: 0
    pauseAfter: 3.5
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041D\u0435 \u0437\u043D\u0430\u044E."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0412\u0435\u0434\u044C \u044F \u043D\u0435 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439,
      \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u0431\u0435 \u0434\u0430\u043D\u043E
      \u043F\u043E\u043D\u044F\u0442\u044C."
    duration: 0
    pauseAfter: 3
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u043F\u043E\u044D\u0442\u043E\u043C\u0443
      \u0442\u044B \u0437\u0434\u0435\u0441\u044C."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0422\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u0431\u0435 \u0434\u0430\u043D\u043E
      \u043E\u0446\u0435\u043D\u0438\u0442\u044C..."
    duration: 0
    pauseAfter: 1.5
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0412\u0441\u044E \u0433\u043B\u0443\u0431\u0438\u043D\u0443 \u0437\u0430\u043C\u044B\u0441\u043B\u0430
      \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0430."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  nextSequence: {fileID: 11400000, guid: 6dd205dec02640446ba8b031822ceb3f, type: 2}
