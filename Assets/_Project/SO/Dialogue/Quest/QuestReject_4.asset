  m_Name: QuestReject_4
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - textEn: Good grief.
    text: "\u0413\u043E\u0441\u043F\u043E\u0434\u0438."
    pauseAfter: 1.5
    activateObject: 
  - textEn: You're not even trying, are you?
    text: "\u0412\u044B \u0432\u0435\u0434\u044C \u0434\u0430\u0436\u0435 \u043D\u0435
      \u0441\u0442\u0430\u0440\u0430\u0435\u0442\u0435\u0441\u044C, \u0434\u0430?"
    pauseAfter: 2
    activateObject: 
  - textEn: Fine. I'll handle this deeply complex task for you.
    text: "\u041B\u0430\u0434\u043D\u043E. \u042F \u0432\u044B\u043F\u043E\u043B\u043D\u044E
      \u044D\u0442\u0443 \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0443\u044E
      \u0437\u0430\u0434\u0430\u0447\u0443 \u0437\u0430 \u0412\u0430\u0441."
    pauseAfter: 2
    activateObject: 
  - textEn: Watch and learn.
    text: "\u0421\u043C\u043E\u0442\u0440\u0438\u0442\u0435 \u0438 \u0443\u0447\u0438\u0442\u0435\u0441\u044C."
    pauseAfter: 2
    activateObject: 
