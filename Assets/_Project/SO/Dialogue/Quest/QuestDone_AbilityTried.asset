  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: QuestDone_AbilityTried
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - textEn: Magnificent choice!
    text: "\u0412\u0435\u043B\u0438\u043A\u043E\u043B\u0435\u043F\u043D\u044B\u0439
      \u0432\u044B\u0431\u043E\u0440!"
    pauseAfter: 2
    activateObject: 
  - textEn: Hmm... It seems...
    text: "\u0425\u043C... \u041F\u043E\u0445\u043E\u0436\u0435..."
    pauseAfter: 1.5
    activateObject: 
  - textEn: The Developer left the skills as UI placeholders.
    text: "\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A \u043E\u0441\u0442\u0430\u0432\u0438\u043B
      \u043D\u0430\u0432\u044B\u043A\u0438 \u043A\u0430\u043A UI-\u0437\u0430\u0433\u043B\u0443\u0448\u043A\u0443."
    pauseAfter: 3.5
    activateObject: 
  - textEn: They do absolutely nothing.
    text: "\u041E\u043D\u0438 \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0434\u0435\u043B\u0430\u044E\u0442.
      \u0421\u043E\u0432\u0441\u0435\u043C."
    pauseAfter: 2.5
    activateObject: 
  - textEn: Then again, the illusion of choice...
    text: "\u0412\u043F\u0440\u043E\u0447\u0435\u043C, \u0438\u043B\u043B\u044E\u0437\u0438\u044F
      \u0432\u044B\u0431\u043E\u0440\u0430..."
    pauseAfter: 2
    activateObject: 
  - textEn: Is the foundation of modern game design.
    text: "\u042D\u0442\u043E \u0431\u0430\u0437\u0430 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
      \u0433\u0435\u0439\u043C-\u0434\u0438\u0437\u0430\u0439\u043D\u0430."
    pauseAfter: 2.5
    activateObject: 
  - textEn: In any case, congratulations on leveling up.
    text: "\u0412 \u043B\u044E\u0431\u043E\u043C \u0441\u043B\u0443\u0447\u0430\u0435
      \u043F\u043E\u0437\u0434\u0440\u0430\u0432\u043B\u044F\u044E \u0441 \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u0435\u043C
      \u0443\u0440\u043E\u0432\u043D\u044F."
    pauseAfter: 3.5
    activateObject: 
  nextSequence: {fileID: 11400000, guid: d8987695e569f9b45b2972d8ce9b77c9, type: 2}
  priority: 5
  restoreInterrupted: 0
