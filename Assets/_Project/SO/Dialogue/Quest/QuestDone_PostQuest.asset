  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: QuestDone_PostQuest
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - textEn: And there you have it. Quest completed.
    text: "\u041D\u0443 \u0432\u043E\u0442. \u0412\u044B \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u043B\u0438
      \u043A\u0432\u0435\u0441\u0442."
    pauseAfter: 2
    activateObject: 
  - textEn: Though the paintings are now completely broken...
    text: "\u041F\u0440\u0430\u0432\u0434\u0430, \u043A\u0430\u0440\u0442\u0438\u043D\u044B
      \u043E\u0442 \u044D\u0442\u043E\u0433\u043E \u0441\u043B\u043E\u043C\u0430\u043B\u0438\u0441\u044C
      \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E..."
    pauseAfter: 2
    activateObject: 
  - textEn: But you earned 1000 experience points!
    text: "\u0417\u0430\u0442\u043E \u0412\u044B \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
      1000 \u043E\u0447\u043A\u043E\u0432 \u043E\u043F\u044B\u0442\u0430!"
    pauseAfter: 2
    activateObject: 
  - textEn: Which you have absolutely nowhere to spend.
    text: "\u041A\u043E\u0442\u043E\u0440\u044B\u0435 \u0412\u0430\u043C \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
      \u043D\u0435\u043A\u0443\u0434\u0430 \u0442\u0440\u0430\u0442\u0438\u0442\u044C."
    pauseAfter: 2
    activateObject: 
  - textEn: Hold on, I found something in the UI.
    text: "\u041F\u043E\u0433\u043E\u0434\u0438\u0442\u0435-\u043A\u0430, \u044F
      \u043A\u043E\u0435-\u0447\u0442\u043E \u043D\u0430\u0448\u0451\u043B \u0432
      \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0435."
    pauseAfter: 2
    activateObject: 
  - textEn: There's an XP bar. How classic.
    text: "\u0417\u0434\u0435\u0441\u044C \u0435\u0441\u0442\u044C \u043F\u043E\u043B\u043E\u0441\u043A\u0430
      \u043E\u043F\u044B\u0442\u0430. \u041A\u0430\u043A\u0430\u044F \u043A\u043B\u0430\u0441\u0441\u0438\u043A\u0430."
    pauseAfter: 2
    activateObject: 
  nextSequence: {fileID: 0}
  priority: 5
  restoreInterrupted: 0
