  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: Seq_Ambient_41
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - textEn: When it runs out, nothing will happen to you.
    text: "\u041F\u043E \u0435\u0433\u043E \u0438\u0441\u0442\u0435\u0447\u0435\u043D\u0438\u0438
      \u0441 \u0412\u0430\u043C\u0438 \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
      \u0441\u043B\u0443\u0447\u0438\u0442\u0441\u044F."
    pauseAfter: 2
    activateObject: 
  - textEn: Just a fun little thing.
    text: "\u041F\u0440\u043E\u0441\u0442\u043E \u0437\u0430\u0431\u0430\u0432\u043D\u0430\u044F
      \u0432\u0435\u0449\u044C."
    pauseAfter: 1.5
    activateObject: 
  - textEn: By the way, there's a whole culture...
    text: "\u041A\u0441\u0442\u0430\u0442\u0438, \u0435\u0441\u0442\u044C \u0446\u0435\u043B\u0430\u044F
      \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0430..."
    pauseAfter: 1.5
    activateObject: 
  - textEn: Of completing games as fast as possible.
    text: "\u041F\u0440\u043E\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0438\u0433\u0440
      \u043D\u0430 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C."
    pauseAfter: 1.5
    activateObject: 
  - textEn: It's called Speedrunning.
    text: "\u041D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F Speedrun."
    pauseAfter: 1.5
    activateObject: 
  - textEn: But everything here is scripted.
    text: "\u041D\u043E \u0442\u0443\u0442 \u0432\u0441\u0451 \u0437\u0430\u0441\u043A\u0440\u0438\u043F\u0442\u043E\u0432\u0430\u043D\u043E."
    pauseAfter: 1.5
    activateObject: 
  - textEn: So don't bother trying, there's no point.
    text: "\u0422\u0430\u043A \u0447\u0442\u043E \u043D\u0435 \u043F\u044B\u0442\u0430\u0439\u0442\u0435\u0441\u044C,
      \u0441\u043C\u044B\u0441\u043B\u0430 \u043D\u0435\u0442."
    pauseAfter: 2
    activateObject: 
  nextSequence: {fileID: 11400000, guid: d28e7830a69732e40ad1b6a03251fca3, type: 2}
  priority: 0
  restoreInterrupted: 0
