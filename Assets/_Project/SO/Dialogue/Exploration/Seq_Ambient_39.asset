    pauseAfter: 3.5
    activateObject: 
  - text: "\u041F\u0440\u043E\u0446\u0435\u0441\u0441 \u0443\u0441\u043F\u043E\u043A\u0430\u0438\u0432\u0430\u0435\u0442."
    pauseAfter: 2
    activateObject: 
  - text: "\u041C\u043E\u0436\u0435\u0442, \u0438 \u0437\u0434\u0435\u0441\u044C
      \u0447\u0442\u043E-\u0442\u043E \u0432 \u044D\u0442\u043E\u043C \u0435\u0441\u0442\u044C."
