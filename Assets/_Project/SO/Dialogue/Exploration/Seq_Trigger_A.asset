--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: Seq_Trigger_A
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0421\u0442\u043E\u0439!"
    duration: 0
    pauseAfter: 1.5
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041F\u0440\u0438\u0441\u043C\u043E\u0442\u0440\u0438\u0441\u044C..."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041D\u0430 \u043B\u0435\u0441\u0442\u043D\u0438\u0447\u043D\u043E\u0439
      \u043A\u043B\u0435\u0442\u043A\u0435 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438
      \u0432\u043D\u0438\u0437."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041E. \u042D\u0442\u043E \u0442\u0435\u043A\u0441\u0442\u0443\u0440\u043D\u044B\u0439
      \u0448\u043E\u0432."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041E\u0447\u0435\u0440\u0435\u0434\u043D\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
      \u043D\u0435\u0443\u043C\u0435\u043B\u043E\u0441\u0442\u0438 \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0430."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0427\u0435\u0433\u043E \u0441\u0442\u043E\u0438\u0442 \u0441\u0448\u0438\u0442\u044C
      \u0434\u0432\u0430 \u043C\u0435\u0448\u0430 \u0432 \u043E\u0434\u0438\u043D..."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0427\u0442\u043E\u0431\u044B \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E
      \u0437\u0430\u043F\u0435\u0447\u044C \u0441\u0432\u0435\u0442?"
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041F\u0443\u0441\u0442\u044C \u0438 \u043C\u043D\u043E\u0433\u043E\u0433\u043E,
      \u043D\u043E \u0432\u0441\u0451 \u0436\u0435..."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A \u044F\u0432\u043D\u043E
      \u043D\u0435 \u0432 \u0442\u0435\u043C\u0435."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0425\u043E\u0442\u044F, \u0433\u043E\u043D\u044F\u044F\u0441\u044C \u0437\u0430
      \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E..."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0414\u0440\u0443\u0433\u0438\u0435 \u0434\u0435\u043B\u0430\u044E\u0442
      \u043F\u0440\u043E\u0435\u043A\u0442\u044B \u0433\u043E\u0434\u0430\u043C\u0438."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0410 \u043F\u043E\u0442\u043E\u043C \u0432\u044B\u0433\u043E\u0440\u0430\u044E\u0442
      \u0438 \u0431\u0440\u043E\u0441\u0430\u044E\u0442."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u042D\u0442\u043E\u0442 \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A
      \u0436\u0435 \u043F\u0440\u043E\u0435\u043A\u0442 \u043D\u0435 \u0431\u0440\u043E\u0441\u0438\u043B."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041F\u0440\u043E\u0441\u0442\u043E \u0432\u044B\u043B\u043E\u0436\u0438\u043B
      \u043A\u0430\u043A \u0435\u0441\u0442\u044C."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u042D\u0442\u043E \u043B\u0438\u0431\u043E \u0431\u0435\u0437\u0440\u0430\u0441\u0441\u0443\u0434\u043D\u043E..."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041B\u0438\u0431\u043E \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E
      \u0441\u043C\u0435\u043B\u043E."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041D\u043E \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A
      \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u044D\u0442\u0443 \u0440\u0435\u043F\u043B\u0438\u043A\u0443."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0417\u043D\u0430\u0447\u0438\u0442, \u044F\u0432\u043D\u043E \u043F\u0435\u0440\u0444\u0435\u043A\u0446\u0438\u043E\u043D\u0438\u0441\u0442."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0412 \u043B\u044E\u0431\u043E\u043C \u0441\u043B\u0443\u0447\u0430\u0435
      \u044D\u0442\u043E \u043D\u0435 \u0442\u0430\u043A \u0432\u0430\u0436\u043D\u043E."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0412\u0435\u0440\u043D\u0451\u043C\u0441\u044F, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
      \u043A \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0435\u0439 \u0440\u0435\u043F\u043B\u0438\u043A\u0435..."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  nextSequence: {fileID: 0}
  priority: 10
  restoreInterrupted: 1
