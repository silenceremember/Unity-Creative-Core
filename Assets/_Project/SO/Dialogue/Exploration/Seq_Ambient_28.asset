  lines:
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A \u043C\u043E\u0433
      \u0431\u044B \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0438\u0433\u0440\u0443
      \u043F\u0440\u043E \u043A\u043B\u0438\u043A\u0438."
    duration: 0
    pauseAfter: 3
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041D\u043E \u0432\u044B\u0431\u0440\u0430\u043B \u0441\u0434\u0435\u043B\u0430\u0442\u044C
      \u044D\u0442\u043E."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u041F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443, \u0441\u0447\u0438\u0442\u0430\u0435\u0442
      \u043E\u043D..."
    duration: 0
    pauseAfter: 1.5
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u042D\u0442\u043E \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
      \u0435\u0433\u043E \u043D\u0430\u0432\u044B\u043A\u0438."
    duration: 0
    pauseAfter: 2
    audioClip: {fileID: 0}
    activateObject: 
  - speaker: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A"
    text: "\u0423\u0432\u0430\u0436\u0430\u044E."
    duration: 0
    pauseAfter: 1.5
    audioClip: {fileID: 0}
    activateObject: 
