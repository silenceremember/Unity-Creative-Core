  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - textEn: I think humanity seeks comfort...
    text: "\u042F \u0434\u0443\u043C\u0430\u044E, \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u043E
      \u0438\u0449\u0435\u0442 \u0443\u0441\u043F\u043E\u043A\u043E\u0435\u043D\u0438\u0435..."
    pauseAfter: 3
    activateObject: 
  - textEn: In unexpected places.
    text: "\u0412 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445
      \u043C\u0435\u0441\u0442\u0430\u0445."
    pauseAfter: 2
    activateObject: 
  - textEn: And sometimes actually finds it.
    text: "\u0418 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u0438\u043D\u043E\u0433\u0434\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u0442."
    pauseAfter: 2
    activateObject: 
