  lines:
  - text: "\u041D\u0435\u0442 \u0441\u043A\u0440\u044B\u0442\u043E\u0439 \u0446\u0435\u043B\u0438."
    pauseAfter: 2
    activateObject: 
  - text: "\u041D\u0435\u0442 \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0437\u0430
      \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F."
    pauseAfter: 2.5
    activateObject: 
  - text: "\u0422\u043E\u043B\u044C\u043A\u043E \u0437\u0432\u0443\u043A \u0438 \u0447\u0438\u0441\u043B\u043E."
    pauseAfter: 2
    activateObject: 
  - text: "\u0425\u043E\u0442\u044F \u0441\u0435\u0439\u0447\u0430\u0441 \u0432\u0441\u0451
      \u043F\u0440\u0438\u043D\u044F\u0442\u043E \u043F\u0438\u0447\u043A\u0430\u0442\u044C..."
    pauseAfter: 2
    activateObject: 
  - text: "\u041C\u0435\u0442\u0430\u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u0435\u0439."
