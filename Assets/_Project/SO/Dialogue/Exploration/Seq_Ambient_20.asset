  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: Seq_Ambient_20
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - textEn: Mary and John aren't going anywhere.
    text: "\u041C\u044D\u0440\u0438 \u0438 \u0414\u0436\u043E\u043D \u043D\u0438\u043A\u0443\u0434\u0430
      \u043D\u0435 \u0443\u0439\u0434\u0443\u0442."
    pauseAfter: 2
    activateObject: 
  - textEn: They'll be here forever.
    text: "\u041E\u043D\u0438 \u0431\u0443\u0434\u0443\u0442 \u0437\u0434\u0435\u0441\u044C
      \u0432\u0441\u0435\u0433\u0434\u0430."
    pauseAfter: 2
    activateObject: 
  - textEn: They don't have the option of escapism.
    text: "\u0423 \u043D\u0438\u0445 \u043D\u0435\u0442 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0435\u0439
      \u0434\u043B\u044F \u044D\u0441\u043A\u0430\u043F\u0438\u0437\u043C\u0430."
    pauseAfter: 2
    activateObject: 
  - textEn: But there's something to that.
    text: "\u041D\u043E \u0435\u0441\u0442\u044C \u0447\u0442\u043E-\u0442\u043E
      \u0432 \u044D\u0442\u043E\u043C."
    pauseAfter: 2
    activateObject: 
  nextSequence: {fileID: 11400000, guid: 6849a6d7daaaef64289e53e58dd9c0e8, type: 2}
  priority: 0
  restoreInterrupted: 0
