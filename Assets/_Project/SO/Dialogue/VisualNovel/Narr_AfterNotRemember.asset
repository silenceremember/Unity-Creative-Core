  m_Name: Narr_AfterNotRemember
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - textEn: She didn't call anyone.
    text: "\u041E\u043D\u0430 \u043D\u0435 \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u0430."
    pauseAfter: 1
    activateObject: 
  - textEn: She has no memories before this scene.
    text: "\u0412\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0439
      \u0434\u043E \u044D\u0442\u043E\u0439 \u0441\u0446\u0435\u043D\u044B \u0443
      \u043D\u0435\u0451 \u043D\u0435\u0442."
    pauseAfter: 1.8
    activateObject: 
  - textEn: Where you came from isn't entirely clear either.
    text: "\u041E\u0442\u043A\u0443\u0434\u0430 \u0432\u0437\u044F\u043B\u0438\u0441\u044C
      \u0412\u044B, \u0442\u043E\u0436\u0435 \u043D\u0435 \u0432\u043F\u043E\u043B\u043D\u0435
      \u044F\u0441\u043D\u043E."
    pauseAfter: 1.8
    activateObject: 
