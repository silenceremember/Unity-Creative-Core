--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: Narr_Ending
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - textEn: It seems...
    text: "\u041F\u043E\u0445\u043E\u0436\u0435..."
    pauseAfter: 0.8
    activateObject: 
  - textEn: They never figured out who you are.
    text: "\u041E\u043D\u0438 \u0442\u0430\u043A \u0438 \u043D\u0435 \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C,
      \u043A\u0442\u043E \u0412\u044B."
    pauseAfter: 1.8
    activateObject: 
  - textEn: Neither did you, most likely.
    text: "\u0412\u044B, \u0432\u043F\u0440\u043E\u0447\u0435\u043C, \u0441\u043A\u043E\u0440\u0435\u0435
      \u0432\u0441\u0435\u0433\u043E, \u0442\u043E\u0436\u0435."
    pauseAfter: 1.2
    activateObject: 
  - textEn: In any case.
    text: "\u0412 \u043B\u044E\u0431\u043E\u043C \u0441\u043B\u0443\u0447\u0430\u0435."
    pauseAfter: 1
    activateObject: 
  - textEn: You just played a visual novel.
    text: "\u0412\u044B \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u043F\u043E\u0438\u0433\u0440\u0430\u043B\u0438
      \u0432 \u0432\u0438\u0437\u0443\u0430\u043B\u044C\u043D\u0443\u044E \u043D\u043E\u0432\u0435\u043B\u043B\u0443."
    pauseAfter: 1.8
    activateObject: 
  - textEn: The Developer thinks these are generally boring.
    text: "\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A \u0441\u0447\u0438\u0442\u0430\u0435\u0442,
      \u0447\u0442\u043E \u044D\u0442\u043E, \u043A\u0430\u043A \u043F\u0440\u0430\u0432\u0438\u043B\u043E,
      \u0441\u043A\u0443\u0447\u043D\u043E."
    pauseAfter: 1.8
    activateObject: 
  - textEn: Sit. Read. Press 'Next'.
    text: "\u0421\u0438\u0434\u0435\u0442\u044C. \u0427\u0438\u0442\u0430\u0442\u044C.
      \u041D\u0430\u0436\u0438\u043C\u0430\u0442\u044C \xAB\u0414\u0430\u043B\u0435\u0435\xBB."
    pauseAfter: 1.2
    activateObject: 
  - textEn: Not exactly thrilling.
    text: "\u041D\u0435 \u043E\u0447\u0435\u043D\u044C-\u0442\u043E \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442."
    pauseAfter: 1
    activateObject: 
  - textEn: So... the next step...
    text: "\u041F\u043E\u044D\u0442\u043E\u043C\u0443... \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C
      \u0448\u0430\u0433\u043E\u043C..."
    pauseAfter: 1
    activateObject: 
  - textEn: Literally a step.
    text: "\u0412 \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E\u043C \u0441\u043C\u044B\u0441\u043B\u0435
      \u0448\u0430\u0433\u043E\u043C."
    pauseAfter: 1
    activateObject: 
  - textEn: He unlocked for you...
    text: "\u041E\u043D \u0440\u0430\u0437\u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043B
      \u0434\u043B\u044F \u0412\u0430\u0441..."
    pauseAfter: 1
    activateObject: 
  - textEn: Walking.
    text: "\u0425\u043E\u0434\u044C\u0431\u0443."
    pauseAfter: 1.1
    activateObject: 
  - textEn: WASD. Any key of your choice.
    text: "WASD. \u041B\u044E\u0431\u0430\u044F \u043A\u043D\u043E\u043F\u043A\u0430
      \u043D\u0430 \u0412\u0430\u0448 \u0432\u044B\u0431\u043E\u0440."
    pauseAfter: 1.5
    activateObject: 
  - textEn: Before you lies a room.
    text: "\u041F\u0435\u0440\u0435\u0434 \u0412\u0430\u043C\u0438 \u043A\u043E\u043C\u043D\u0430\u0442\u0430."
    pauseAfter: 1
    activateObject: 
  - textEn: Walk around. Look at things.
    text: "\u0425\u043E\u0434\u0438\u0442\u0435. \u0421\u043C\u043E\u0442\u0440\u0438\u0442\u0435
      \u043D\u0430 \u0432\u0435\u0449\u0438."
    pauseAfter: 1
    activateObject: 
  nextSequence: {fileID: 0}
  priority: 0
  restoreInterrupted: 0
