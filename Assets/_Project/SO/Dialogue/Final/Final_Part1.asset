  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - text: "\u0418\u0442\u0430\u043A."
    pauseAfter: 2
    activateObject: 
  - text: "\u0412\u044B \u0432\u0441\u0451 \u0436\u0435 \u043F\u0440\u044B\u0433\u043D\u0443\u043B\u0438."
    pauseAfter: 3
    activateObject: 
  - text: "\u041D\u043E, \u0431\u043E\u044E\u0441\u044C, \u043C\u043D\u0435 \u043F\u0440\u0438\u0434\u0451\u0442\u0441\u044F
      \u0412\u0430\u0441 \u043E\u0433\u043E\u0440\u0447\u0438\u0442\u044C."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u042F \u0412\u0430\u0441 \u043E\u0431\u043C\u0430\u043D\u0443\u043B."
    pauseAfter: 3
    activateObject: 
  - text: "\u0421\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F
      \u043D\u0435 \u0431\u0443\u0434\u0435\u0442."
    pauseAfter: 3
    activateObject: 
  - text: "\u0418 \u0432\u043E\u043E\u0431\u0449\u0435 \u043D\u0438\u0447\u0435\u0433\u043E
      \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435 \u0431\u0443\u0434\u0435\u0442."
    pauseAfter: 3
    activateObject: 
  - text: "\u041F\u043E \u043A\u0440\u0430\u0439\u043D\u0435\u0439 \u043C\u0435\u0440\u0435
      \u0434\u043B\u044F \u043C\u0435\u043D\u044F."
    pauseAfter: 4
    activateObject: 
  - text: "\u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0432\u044B\u0439\u0442\u0438
      \u0432 \u043B\u044E\u0431\u043E\u0439 \u043C\u043E\u043C\u0435\u043D\u0442."
    pauseAfter: 4
    activateObject: 
