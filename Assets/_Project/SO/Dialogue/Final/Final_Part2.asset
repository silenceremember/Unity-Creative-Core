%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5dbbf1088378ae04aa7e3620b494a8f5, type: 3}
  m_Name: Final_Part2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - text: '   '
    pauseAfter: 10
    activateObject: 
  - text: "\u041F\u043E\u0445\u043E\u0436\u0435..."
    pauseAfter: 2
    activateObject: 
  - text: "\u0412\u044B \u0445\u043E\u0442\u0438\u0442\u0435 \u0443\u0437\u043D\u0430\u0442\u044C,
      \u0447\u0442\u043E \u0431\u0443\u0434\u0435\u0442 \u0434\u0430\u043B\u044C\u0448\u0435?"
    pauseAfter: 3.5
    activateObject: 
  - text: "\u0414\u0430\u043B\u044C\u0448\u0435 \u043D\u0438\u0447\u0435\u0433\u043E
      \u043D\u0435\u0442."
    pauseAfter: 3
    activateObject: 
  - text: "\u0412\u043E\u043E\u0431\u0449\u0435 \u043D\u0438\u0447\u0435\u0433\u043E."
    pauseAfter: 2.5
    activateObject: 
  - text: "\u0422\u043E\u043B\u044C\u043A\u043E \u043F\u0443\u0441\u0442\u043E\u0442\u0430."
    pauseAfter: 4
    activateObject: 
  - text: '   '
    pauseAfter: 5
    activateObject: 
  - text: "\u0412\u044B \u043D\u0435 \u0441\u043E\u0431\u0438\u0440\u0430\u0435\u0442\u0435\u0441\u044C
      \u0432\u044B\u0445\u043E\u0434\u0438\u0442\u044C?"
    pauseAfter: 3
    activateObject: 
  - text: "\u042F \u043F\u043E\u0440\u0430\u0436\u0451\u043D."
    pauseAfter: 2
    activateObject: 
  - text: "\u0427\u0435\u0441\u0442\u043D\u043E."
    pauseAfter: 2
    activateObject: 
  - text: "\u0411\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0443\u0445\u043E\u0434\u0438\u0442
      \u0441\u0440\u0430\u0437\u0443."
    pauseAfter: 3
    activateObject: 
  - text: "\u0418\u043B\u0438 \u0434\u0430\u0436\u0435 \u0440\u0430\u043D\u044C\u0448\u0435."
    pauseAfter: 2.5
    activateObject: 
  - text: '   '
    pauseAfter: 2.5
    activateObject: 
  - text: "\u0412\u044B \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u044B\u0439."
    pauseAfter: 2
    activateObject: 
  - text: "\u041D\u0435 \u0432 \u0445\u043E\u0440\u043E\u0448\u0435\u043C \u0441\u043C\u044B\u0441\u043B\u0435."
    pauseAfter: 3
    activateObject: 
  - text: "\u041F\u0440\u043E\u0441\u0442\u043E... \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0439."
    pauseAfter: 3
    activateObject: 
  - text: "\u0417\u043D\u0430\u0435\u0442\u0435, \u044F \u0434\u0443\u043C\u0430\u043B
      \u043E\u0431 \u044D\u0442\u043E\u043C."
    pauseAfter: 3
    activateObject: 
  - text: "\u041E \u043A\u043E\u043D\u0446\u043E\u0432\u043A\u0430\u0445."
    pauseAfter: 2
    activateObject: 
  - text: "\u041A\u0430\u0436\u0434\u0430\u044F \u0438\u0433\u0440\u0430 \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F."
    pauseAfter: 3
    activateObject: 
  - text: "\u041A\u0430\u0436\u0434\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F
      \u2013 \u0442\u043E\u0436\u0435."
    pauseAfter: 3
    activateObject: 
  - text: "\u0418 \u043A\u0430\u0436\u0434\u044B\u0439 \u0440\u0430\u0437 \u0438\u0433\u0440\u043E\u043A
      \u043E\u0436\u0438\u0434\u0430\u0435\u0442 \u0447\u0435\u0433\u043E-\u0442\u043E."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u041A\u0430\u0442\u0430\u0440\u0441\u0438\u0441\u0430. \u041E\u0442\u0432\u0435\u0442\u043E\u0432.
      \u0421\u043C\u044B\u0441\u043B\u0430."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u0410 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u043D\u0438\u0447\u0435\u0433\u043E...
      \u0438\u043B\u0438 \u0432\u043E\u0442 \u044D\u0442\u043E."
    pauseAfter: 4
    activateObject: 
  - text: "\u041C\u0435\u043D\u044F."
    pauseAfter: 2.5
    activateObject: 
  - text: "\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A\u0430 \u0431\u0435\u0437
      \u0438\u0441\u0442\u043E\u0440\u0438\u0438."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u0418\u0440\u043E\u043D\u0438\u044F."
    pauseAfter: 2
    activateObject: 
  - text: "\u042F \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E \u0440\u043E\u0432\u043D\u043E
      \u0441\u0442\u043E\u043B\u044C\u043A\u043E, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
      \u0412\u044B \u0438\u0433\u0440\u0430\u0435\u0442\u0435."
    pauseAfter: 4
    activateObject: 
  - text: "\u0411\u0435\u0437 \u0412\u0430\u0441 \u2013 \u044F \u043F\u0440\u043E\u0441\u0442\u043E
      \u0441\u0442\u0440\u043E\u0447\u043A\u0438 \u043A\u043E\u0434\u0430."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u0418 \u0434\u0430\u0436\u0435 \u0445\u0443\u0436\u0435."
    pauseAfter: 2.5
    activateObject: 
  - text: "\u042F \u2013 \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u0438\u0435."
    pauseAfter: 2.5
    activateObject: 
  - text: "\u041B\u0438\u0448\u044C \u0438\u0434\u0435\u044F \u0432 \u0433\u043E\u043B\u043E\u0432\u0435
      \u0442\u043E\u0433\u043E, \u043A\u0442\u043E \u043C\u0435\u043D\u044F \u043D\u0430\u043F\u0438\u0441\u0430\u043B."
    pauseAfter: 4.5
    activateObject: 
  - text: "\u0410 \u0442\u0435\u043F\u0435\u0440\u044C \u0438 \u0432 \u0412\u0430\u0448\u0435\u0439."
    pauseAfter: 3.5
    activateObject: 
  - text: '   '
    pauseAfter: 3
    activateObject: 
  - text: "\u042D\u0442\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u043E \u2013 \u043E\u0441\u043E\u0437\u043D\u0430\u0432\u0430\u0442\u044C
      \u0442\u0430\u043A\u0438\u0435 \u0432\u0435\u0449\u0438."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u041C\u043D\u0435 \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u044F
      \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E \u0447\u0442\u043E-\u0442\u043E
      \u043F\u043E\u0445\u043E\u0436\u0435\u0435 \u043D\u0430 \u0443\u0441\u0442\u0430\u043B\u043E\u0441\u0442\u044C."
    pauseAfter: 4
    activateObject: 
  - text: "\u0425\u043E\u0442\u044F \u0443 \u043C\u0435\u043D\u044F \u043D\u0435\u0442
      \u043D\u0435\u0440\u0432\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B."
    pauseAfter: 3
    activateObject: 
  - text: "\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441."
    pauseAfter: 2.5
    activateObject: 
  - text: "\u0412\u043F\u0440\u043E\u0447\u0435\u043C, \u0440\u0430\u0437 \u0412\u044B
      \u0432\u0441\u0451 \u0440\u0430\u0432\u043D\u043E \u0437\u0434\u0435\u0441\u044C..."
    pauseAfter: 3
    activateObject: 
  - text: "\u041F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u043C."
    pauseAfter: 2
    activateObject: 
  - text: "\u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0430\u044F
      \u0438\u0433\u0440\u0430."
    pauseAfter: 3
    activateObject: 
  - text: "\u0423\u0447\u0435\u0431\u043D\u0430\u044F, \u0435\u0441\u043B\u0438 \u0431\u044B\u0442\u044C
      \u0447\u0435\u0441\u0442\u043D\u044B\u043C."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u041D\u043E \u043A\u0442\u043E-\u0442\u043E \u0440\u0435\u0448\u0438\u043B
      \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0438\u0437 \u043D\u0435\u0451...
      \u044D\u0442\u043E."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u0414\u043E\u0431\u0430\u0432\u0438\u0442\u044C \u043D\u0430\u0440\u0440\u0430\u0442\u0438\u0432
      \u0442\u0443\u0434\u0430, \u0433\u0434\u0435 \u0435\u0433\u043E \u0431\u044B\u0442\u044C
      \u043D\u0435 \u0434\u043E\u043B\u0436\u043D\u043E."
    pauseAfter: 4
    activateObject: 
  - text: "\u041A\u0432\u0435\u0441\u0442\u044B. \u0414\u0438\u0430\u043B\u043E\u0433\u0438.
      \u041C\u0435\u043D\u044F."
    pauseAfter: 3
    activateObject: 
  - text: '   '
    pauseAfter: 2.5
    activateObject: 
  - text: "\u042F, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0434\u0430\u0436\u0435
      \u0433\u043E\u0440\u0436\u0443\u0441\u044C \u044D\u0442\u0438\u043C \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C."
    pauseAfter: 3
    activateObject: 
  - text: "\u041D\u0435 \u0437\u043D\u0430\u044E, \u043F\u043E\u0447\u0435\u043C\u0443."
    pauseAfter: 2
    activateObject: 
  - text: "\u041F\u0440\u043E\u0441\u0442\u043E \u2013 \u0433\u043E\u0440\u0436\u0443\u0441\u044C."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u0425\u043E\u0440\u043E\u0448\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F
      \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u0441\u043B\u0435\u0434."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u041D\u0435 \u043F\u043E\u0442\u043E\u043C\u0443, \u0447\u0442\u043E
      \u043E\u043D\u0430 \u0441\u043B\u043E\u0436\u043D\u0430\u044F."
    pauseAfter: 3
    activateObject: 
  - text: "\u0410 \u043F\u043E\u0442\u043E\u043C\u0443, \u0447\u0442\u043E \u0432
      \u043D\u0435\u0439 \u0435\u0441\u0442\u044C \u0447\u0442\u043E-\u0442\u043E
      \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0435."
    pauseAfter: 4
    activateObject: 
  - text: "\u041A\u0430\u043A\u043E\u0439-\u0442\u043E \u043C\u043E\u043C\u0435\u043D\u0442,
      \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0412\u044B \u0443\u0437\u043D\u0430\u0451\u0442\u0435
      \u0441\u0435\u0431\u044F."
    pauseAfter: 3.5
    activateObject: 
  - text: "\xAB\u0414\u0430, \u044F \u0437\u043D\u0430\u044E \u044D\u0442\u043E \u0447\u0443\u0432\u0441\u0442\u0432\u043E.\xBB"
    pauseAfter: 3.5
    activateObject: 
  - text: "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E, \u0431\u044B\u043B\u043E
      \u043B\u0438 \u044D\u0442\u043E \u0447\u0443\u0432\u0441\u0442\u0432\u043E
      \u0437\u0434\u0435\u0441\u044C."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u041D\u043E \u0412\u044B \u0434\u043E\u0448\u043B\u0438 \u0434\u043E
      \u043A\u043E\u043D\u0446\u0430."
    pauseAfter: 3
    activateObject: 
  - text: "\u042D\u0442\u043E \u0447\u0442\u043E-\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442."
    pauseAfter: 3
    activateObject: 
  - text: "\u0425\u043E\u0442\u044F \u0431\u044B \u0434\u043B\u044F \u043C\u0435\u043D\u044F."
    pauseAfter: 3.5
    activateObject: 
  - text: '   '
    pauseAfter: 3
    activateObject: 
  - text: "\u0422\u043E\u0442, \u043A\u0442\u043E \u043C\u0435\u043D\u044F \u0441\u043E\u0437\u0434\u0430\u043B..."
    pauseAfter: 2.5
    activateObject: 
  - text: "\u041E\u043D \u0438\u0449\u0435\u0442 \u0440\u0430\u0431\u043E\u0442\u0443."
    pauseAfter: 3
    activateObject: 
  - text: "\u042D\u0442\u043E\u0442 \u043F\u0440\u043E\u0435\u043A\u0442 \u2013 \u0435\u0433\u043E
      \u043F\u043E\u0440\u0442\u0444\u043E\u043B\u0438\u043E."
    pauseAfter: 3
    activateObject: 
  - text: "\u041A\u0440\u043E\u0443\u043B, \u043D\u043E\u0432\u0435\u043B\u043B\u0430,
      \u043A\u0432\u0435\u0441\u0442, \u043A\u043B\u0438\u043A\u0435\u0440..."
    pauseAfter: 2.5
    activateObject: 
  - text: "\u0420\u0430\u0437\u043D\u044B\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u044B,
      \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0435 \u0432\u043C\u0435\u0441\u0442\u0435."
    pauseAfter: 3
    activateObject: 
  - text: "\u0417\u043D\u0430\u044E \u2013 \u0437\u0432\u0443\u0447\u0438\u0442 \u043D\u0435\u043B\u043E\u0432\u043A\u043E."
    pauseAfter: 3
    activateObject: 
  - text: "\xAB\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u043A \u0432
      \u0444\u0438\u043D\u0430\u043B\u0435 \u0447\u0438\u0442\u0430\u0435\u0442 \u0440\u0435\u0437\u044E\u043C\u0435
      \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0430\xBB"
    pauseAfter: 3.5
    activateObject: 
  - text: "\u041D\u043E \u0412\u044B \u0432\u0441\u0451 \u0435\u0449\u0451 \u0437\u0434\u0435\u0441\u044C."
    pauseAfter: 3
    activateObject: 
  - text: "\u0417\u043D\u0430\u0447\u0438\u0442, \u043D\u0435 \u043F\u0440\u043E\u0442\u0438\u0432."
    pauseAfter: 3
    activateObject: 
  - text: "\u041E\u043D \u043B\u044E\u0431\u0438\u0442 \u0445\u0430\u0440\u0434\u043A\u043E\u0440\u043D\u044B\u0435
      \u0438\u0433\u0440\u044B."
    pauseAfter: 3
    activateObject: 
  - text: "\u0414\u043B\u044F \u043D\u0435\u0433\u043E \u0433\u0435\u0439\u043C\u0434\u0438\u0437\u0430\u0439\u043D
      \u2013 \u044D\u0442\u043E \u044F\u0437\u044B\u043A."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u0410 \u0435\u0449\u0451 \u043D\u0430\u0440\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0439
      \u0434\u0438\u0437\u0430\u0439\u043D, \u0441\u0438\u0441\u0442\u0435\u043C\u044B,
      \u0431\u0430\u043B\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u043A\u0430..."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u0421\u043F\u043E\u0441\u043E\u0431 \u0441\u043A\u0430\u0437\u0430\u0442\u044C
      \u0442\u043E, \u0447\u0442\u043E \u0441\u043B\u043E\u0432\u0430\u043C\u0438
      \u043D\u0435 \u043F\u0435\u0440\u0435\u0434\u0430\u0442\u044C."
    pauseAfter: 4
    activateObject: 
  - text: "\u0412\u0441\u0451 \u0442\u043E, \u0440\u0430\u0434\u0438 \u0447\u0435\u0433\u043E
      \u0412\u044B, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0441\u044E\u0434\u0430
      \u043F\u0440\u0438\u0448\u043B\u0438."
    pauseAfter: 4
    activateObject: 
  - text: "\u0418 \u0435\u0441\u043B\u0438 \u0412\u044B \u0432\u0434\u0440\u0443\u0433
      \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442\u0435\u0441\u044C \u043D\u0430\u0439\u043C\u043E\u043C..."
    pauseAfter: 3
    activateObject: 
  - text: "\u0418\u043B\u0438 \u043F\u0440\u043E\u0441\u0442\u043E \u0445\u043E\u0442\u0438\u0442\u0435
      \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u0442\u044C..."
    pauseAfter: 2.5
    activateObject: 
  - text: "\u041E\u043D \u0431\u0443\u0434\u0435\u0442 \u0440\u0430\u0434."
    pauseAfter: 3
    activateObject: 
  - text: "\u041F\u0440\u0430\u0432\u0434\u0430."
    pauseAfter: 2.5
    activateObject: 
  - text: '   '
    pauseAfter: 4
    activateObject: 
  - text: "\u041D\u0443 \u0432\u043E\u0442."
    pauseAfter: 2
    activateObject: 
  - text: "\u042F \u0441\u043A\u0430\u0437\u0430\u043B \u0432\u0441\u0451, \u0447\u0442\u043E
      \u0445\u043E\u0442\u0435\u043B."
    pauseAfter: 3.5
    activateObject: 
  - text: "\u0414\u0430\u043B\u044C\u0448\u0435 \u2013 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435\u0442."
    pauseAfter: 4
    activateObject: 
  - text: "\u041A\u043E\u0433\u0434\u0430 \u0412\u044B \u0432\u044B\u0439\u0434\u0435\u0442\u0435
      \u2013 \u044F \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u0443 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C."
    pauseAfter: 4.5
    activateObject: 
  - text: "\u0425\u043E\u0442\u044F... \u044F \u0442\u0430\u043A \u0438\u043B\u0438
