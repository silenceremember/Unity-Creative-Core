  lines:
  - text: Switching language.
    pauseAfter: 0.8
    activateObject: 
  - text: Back to Russian. Here goes.
    pauseAfter: 1.2
    activateObject: 
  - text: "\u041E. \u042D\u0442\u043E \u0441\u043D\u043E\u0432\u0430 \u044F."
