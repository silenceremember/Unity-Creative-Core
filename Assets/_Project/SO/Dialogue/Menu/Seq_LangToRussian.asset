    pauseAfter: 1
    activateObject: 
  - text: "\u0413\u043E\u0440\u0430\u0437\u0434\u043E \u043C\u0435\u043D\u0435\u0435
      \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E."
    pauseAfter: 1
    activateObject: 
  - text: "\u041F\u043E \u043A\u0440\u0430\u0439\u043D\u0435\u0439 \u043C\u0435\u0440\u0435,
      \u0447\u0435\u0441\u0442\u043D\u043E."
