  ru: "\u0414\u0430\u0432\u043D\u044B\u043C-\u0434\u0430\u0432\u043D\u043E, \u0432
    \u0434\u0430\u043B\u0435\u043A\u043E\u0439 \u0433\u0430\u043B\u0430\u043A\u0442\u0438\u043A\u0435...\n\u0418\u043B\u0438
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u043E\u0440\u0430\u0445 Unity Asset
    Store.\n...\u0418\u043B\u0438 \u0434\u0430\u0436\u0435 \u0447\u0443\u0442\u043E\u0447\u043A\u0443
    \u0434\u0430\u043B\u044C\u0448\u0435.\n\n\u0412 \u043E\u0434\u043D\u043E\u0439
    \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439...\n\u0416\u0438\u043B
    \u043E\u0434\u0438\u043D \u0411\u0435\u0434\u043D\u044B\u0439 \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A,\n\u041A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043C\u0435\u0447\u0442\u0430\u043B \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0418\u0433\u0440\u0443.\n\n\u041D\u0435 \u043F\u043E\u0434\u0435\u043B\u043A\u0443,
    \u0430 \u0418\u0433\u0440\u0443 \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0431\u0443\u043A\u0432\u044B.\n\u0421\u043E\u0442\u043D\u0438 \u043A\u0432\u0435\u0441\u0442\u043E\u0432,
    \u0436\u0438\u0432\u043E\u0439 \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u0439
    \u043C\u0438\u0440.\n\u0423\u0431\u0438\u0439\u0446\u0443 \u0412\u0435\u0434\u044C\u043C\u0430\u043A\u0430.
    \u041F\u043E\u0434\u043B\u0438\u043D\u043D\u044B\u0439 \u0448\u0435\u0434\u0435\u0432\u0440.\n\u0421
    \u0442\u044B\u0441\u044F\u0447\u0430\u043C\u0438 \u0432\u0435\u0442\u0432\u0435\u0439
    \u0434\u0438\u0430\u043B\u043E\u0433\u043E\u0432.\n\u041D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E
    \u0418\u0433\u0440\u0443 \u041C\u0435\u0447\u0442\u044B.\n\n\u041E\u043D \u0442\u043E\u043D\u0443\u043B
    \u0432 \u043F\u0443\u0447\u0438\u043D\u0435 \u0433\u0430\u0439\u0434\u043E\u0432
    \u0438 \u0432\u0438\u0434\u0435\u043E,\n\u041E\u0442\u0442\u044F\u0433\u0438\u0432\u0430\u044F
    \u0432\u0440\u0435\u043C\u044F, \u043D\u043E \u043E\u0434\u043D\u0430\u0436\u0434\u044B
    \u0432\u0441\u0435 \u0436\u0435 \u043D\u0430\u0447\u0430\u043B.\n\u0418 \u0432\u0441\u043A\u043E\u0440\u0435
    \u0432 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435 \u0434\u043E \u043D\u0435\u0433\u043E
    \u0434\u043E\u0448\u043B\u043E:\n\u0414\u043E\u0434\u0435\u043B\u0430\u0442\u044C
    \u0442\u0430\u043A\u043E\u0435 \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438
    \u043D\u0435 \u0432\u044B\u0439\u0434\u0435\u0442.\n\n\u0421\u043F\u0443\u0441\u0442\u044F
    \u0433\u043E\u0434\u044B \u0431\u043E\u043B\u0438 \u0438 \u0431\u0435\u0441\u0447\u0435\u0442\u043D\u044B\u0445
    \u043F\u043E\u043F\u044B\u0442\u043E\u043A,\n\u041E\u043D \u0432\u044B\u0431\u0440\u0430\u043B
    \u0438\u043D\u043E\u0439, \u043A\u0443\u0434\u0430 \u0431\u043E\u043B\u0435\u0435
    \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u0439 \u043F\u0443\u0442\u044C.\n\u0412\u0437\u044F\u043B
    \u0431\u0435\u0441\u043F\u043B\u0430\u0442\u043D\u044B\u0439 \u0448\u0430\u0431\u043B\u043E\u043D
    Unity Pathways\n\u0418 \u0441\u043B\u0435\u043F\u0438\u043B \u0438\u0437 \u043D\u0435\u0433\u043E
    \u043D\u0435\u043A\u043E\u0435 \u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0435.\n\n\u041D\u0430\u0437\u0432\u0430\u0442\u044C
    \u044D\u0442\u043E \u0418\u0433\u0440\u043E\u0439 \u043C\u043E\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u043B\u0438\u0448\u044C \u0441 \u0442\u0440\u0443\u0434\u043E\u043C.\n\n\xAB\u0412\u043F\u0440\u043E\u0447\u0435\u043C,
    \u043F\u043E\u0434\u0443\u043C\u0430\u043B \u043E\u043D,\n\u0421\u0438\u043C\u0443\u043B\u044F\u0442\u043E\u0440\u044B
    \u043A\u0430\u043C\u043D\u044F \u0438 \u0431\u0430\u043D\u0430\u043D\u0430-\u043A\u043B\u0438\u043A\u0435\u0440\u044B\n\u041F\u0440\u0438\u043D\u043E\u0441\u044F\u0442
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044F\u043C \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u0435
    \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u044B.\n\u0417\u0430\u0447\u0435\u043C
    \u043C\u043D\u0435 \u044D\u0442\u0438 \u043B\u043E\u0436\u043D\u044B\u0435 \u0430\u043C\u0431\u0438\u0446\u0438\u0438?\n\u0417\u0430\u0447\u0435\u043C
    \u043C\u043D\u0435 \u044D\u0442\u043E\u0442 \u043C\u0430\u0441\u0448\u0442\u0430\u0431
    \u0438 \u0440\u0430\u0437\u043C\u0430\u0445?\n\u042F \u0441\u0434\u0435\u043B\u0430\u044E
    \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C \u043A\u0440\u043E\u0448\u0435\u0447\u043D\u043E\u0435\xBB.\n\n\u0412\u0440\u0435\u043C\u044F
    \u0448\u043B\u043E, \u0438 \u044D\u0442\u043E \xAB\u043C\u0430\u043B\u043E\u0435\xBB
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C.\n\u0418 \u0434\u0430\u0436\u0435
    \u043E\u043D\u043E, \u043F\u0440\u0438\u0437\u043D\u0430\u0442\u044C\u0441\u044F,
    \u0432\u044B\u0448\u043B\u043E \u0442\u0430\u043A \u0441\u0435\u0431\u0435.\n\u041D\u043E
    \u043E\u043D \u0442\u0432\u0435\u0440\u0434\u043E \u0440\u0435\u0448\u0438\u043B
    \u0432\u044B\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u044D\u0442\u043E \u0432
    \u0441\u0432\u0435\u0442.\n\u041F\u0440\u043E\u0441\u0442\u043E \u0447\u0442\u043E\u0431\u044B
    \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u0433\u0435\u0448\u0442\u0430\u043B\u044C\u0442.\n\u0417\u0430\u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0445\u043E\u0442\u044C \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u0444\u0438\u043D\u0430\u043B.\n\n\u041B\u044E\u0434\u0438
    \u0438\u0433\u0440\u0430\u043B\u0438 \u0432 \u0435\u0433\u043E \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0443\u044E
    \u043F\u043E\u0434\u0435\u043B\u043A\u0443.\n\u0418, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0434\u0443\u043C\u0430\u043B\u0438, \u0447\u0442\u043E \u0430\u0432\u0442\u043E\u0440
    \u043D\u0435 \u043C\u0430\u0441\u0442\u0435\u0440,\n\u041D\u0438\u043A\u0430\u043A\u043E\u0439
    \u043D\u0435 \u0433\u0443\u0440\u0443 \u0438 \u043D\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B.\n\u041D\u0430\u0432\u0435\u0440\u043D\u044F\u043A\u0430
    \u043E\u043D \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u0433\u0435\u043D\u0435\u0440\u0438\u0440\u043E\u0432\u0430\u043B\n\u0412\u0435\u0441\u044C
    \u043F\u0440\u043E\u0435\u043A\u0442 \u0438 \u0442\u0435\u043A\u0441\u0442\u044B
    \u0432 \u043D\u0435\u0439\u0440\u043E\u0441\u0435\u0442\u0438.\n\n\u042D\u0442\u043E
    \u043D\u0435 \u0442\u0430\u043A.\n\n\u041D\u043E \u043A\u0430\u043A \u0431\u044B
    \u043A\u0440\u0438\u0432\u043E \u043D\u0438 \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B
    \u0440\u0435\u043B\u0438\u0437,\n\u0418 \u043A\u0430\u043A \u0431\u044B \u0438\u0433\u0440\u043E\u043A\u0438
    \u0435\u0433\u043E \u043D\u0438 \u043E\u0446\u0435\u043D\u0438\u043B\u0438...\n\u041F\u0440\u043E\u0435\u043A\u0442
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0434\u0440\u0443\u0433\u0438\u0445 \u0432\u0435\u0449\u0435\u0439.\n\n\u0421\u043A\u0440\u0438\u043F\u0442\u0438\u043D\u0433,
    \u043D\u0430\u0440\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0439 \u0438 \u0433\u0435\u0439\u043C-\u0434\u0438\u0437\u0430\u0439\u043D,\n\u0428\u0435\u0439\u0434\u0435\u0440\u044B,
    \u0441\u0432\u0435\u0442, \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B
    \u0438 \u0437\u0432\u0443\u043A,\n\u041A\u0430\u043C\u0435\u0440\u044B, \u043F\u043E\u0441\u0442\u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0438\u043D\u0433,
    \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441,\n\u0410\u043D\u0438\u043C\u0430\u0446\u0438\u0438
    \u0438 \u043F\u0440\u043E\u0447\u0438\u0435 \u044D\u0444\u0444\u0435\u043A\u0442\u044B.\n\u041E\u043D
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0443\u043C\u0435\u0435\u0442
    \u0433\u043B\u0430\u0432\u043D\u043E\u0435:\n\u0414\u043E\u0432\u043E\u0434\u0438\u0442\u044C
    \u0434\u0435\u043B\u043E \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0438 \u0441\u043E\u0431\u0438\u0440\u0430\u0442\u044C
    \u043A\u0443\u0441\u043A\u0438\n\u0412 \u043E\u0434\u043D\u043E \u0435\u0434\u0438\u043D\u043E\u0435,
    \u0440\u0430\u0431\u043E\u0447\u0435\u0435 \u0446\u0435\u043B\u043E\u0435.\n\n\u041F\u0443\u0441\u0442\u044C
    \u0438 \u0442\u0430\u043A.\n\n\u041D\u043E \u0432\u0430\u0436\u043D\u043E \u043D\u0435
    \u0437\u0430\u0431\u044B\u0432\u0430\u0442\u044C \u043E\u0434\u043D\u0443 \u0434\u0435\u0442\u0430\u043B\u044C.\n\u0422\u043E
    \u0431\u044B\u043B\u0430 \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u043D\u0430\u044F
    \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F.\n\u041D\u043E \u2013
    \u044D\u0442\u043E \u043F\u043E\u0434\u043B\u0438\u043D\u043D\u0430\u044F \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C.\n\n\u0418
    \u0432\u0435\u0441\u044C \u044D\u0442\u043E\u0442 \u0442\u0435\u043A\u0441\u0442
    \u0432\u044B\u0448\u0435...\n\u041B\u0438\u0448\u044C \u0430\u043B\u043B\u0435\u0433\u043E\u0440\u0438\u044F
    \u043D\u0430 \u0447\u0430\u0441\u0442\u0443\u044E \u043E\u0448\u0438\u0431\u043A\u0443.\n\u0412\u043E\u0432\u0441\u0435
    \u043D\u0435 \u043F\u0440\u043E \u043D\u0430\u0448\u0443 \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u0443\u044E.\n\n\u0410\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
    \u0442\u043E\u0447\u043D\u043E.\n\n\nMusic by Kevin MacLeod (incompetech.com)\nLicensed
    under CC BY 3.0"
  en: "\u0414\u0430\u0432\u043D\u044B\u043C-\u0434\u0430\u0432\u043D\u043E, \u0432
    \u0434\u0430\u043B\u0435\u043A\u043E\u0439 \u0433\u0430\u043B\u0430\u043A\u0442\u0438\u043A\u0435...\n\u0418\u043B\u0438
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u043E\u0440\u0430\u0445 Unity Asset
    Store.\n...\u0418\u043B\u0438 \u0434\u0430\u0436\u0435 \u0447\u0443\u0442\u043E\u0447\u043A\u0443
    \u0434\u0430\u043B\u044C\u0448\u0435.\n\n\u0412 \u043E\u0434\u043D\u043E\u0439
    \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439...\n\u0416\u0438\u043B
    \u043E\u0434\u0438\u043D \u0411\u0435\u0434\u043D\u044B\u0439 \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A,\n\u041A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043C\u0435\u0447\u0442\u0430\u043B \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0418\u0433\u0440\u0443.\n\n\u041D\u0435 \u043F\u043E\u0434\u0435\u043B\u043A\u0443,
    \u0430 \u0418\u0433\u0440\u0443 \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0431\u0443\u043A\u0432\u044B.\n\u0421\u043E\u0442\u043D\u0438 \u043A\u0432\u0435\u0441\u0442\u043E\u0432,
    \u0436\u0438\u0432\u043E\u0439 \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u0439
    \u043C\u0438\u0440.\n\u0423\u0431\u0438\u0439\u0446\u0443 \u0412\u0435\u0434\u044C\u043C\u0430\u043A\u0430.
    \u041F\u043E\u0434\u043B\u0438\u043D\u043D\u044B\u0439 \u0448\u0435\u0434\u0435\u0432\u0440.\n\u0421
    \u0442\u044B\u0441\u044F\u0447\u0430\u043C\u0438 \u0432\u0435\u0442\u0432\u0435\u0439
    \u0434\u0438\u0430\u043B\u043E\u0433\u043E\u0432.\n\u041D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E
    \u0418\u0433\u0440\u0443 \u041C\u0435\u0447\u0442\u044B.\n\n\u041E\u043D \u0442\u043E\u043D\u0443\u043B
    \u0432 \u043F\u0443\u0447\u0438\u043D\u0435 \u0433\u0430\u0439\u0434\u043E\u0432
    \u0438 \u0432\u0438\u0434\u0435\u043E,\n\u041E\u0442\u0442\u044F\u0433\u0438\u0432\u0430\u044F
    \u0432\u0440\u0435\u043C\u044F, \u043D\u043E \u043E\u0434\u043D\u0430\u0436\u0434\u044B
    \u0432\u0441\u0435 \u0436\u0435 \u043D\u0430\u0447\u0430\u043B.\n\u0418 \u0432\u0441\u043A\u043E\u0440\u0435
    \u0432 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435 \u0434\u043E \u043D\u0435\u0433\u043E
    \u0434\u043E\u0448\u043B\u043E:\n\u0414\u043E\u0434\u0435\u043B\u0430\u0442\u044C
    \u0442\u0430\u043A\u043E\u0435 \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438
    \u043D\u0435 \u0432\u044B\u0439\u0434\u0435\u0442.\n\n\u0421\u043F\u0443\u0441\u0442\u044F
    \u0433\u043E\u0434\u044B \u0431\u043E\u043B\u0438 \u0438 \u0431\u0435\u0441\u0447\u0435\u0442\u043D\u044B\u0445
    \u043F\u043E\u043F\u044B\u0442\u043E\u043A,\n\u041E\u043D \u0432\u044B\u0431\u0440\u0430\u043B
    \u0438\u043D\u043E\u0439, \u043A\u0443\u0434\u0430 \u0431\u043E\u043B\u0435\u0435
    \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u0439 \u043F\u0443\u0442\u044C.\n\u0412\u0437\u044F\u043B
    \u0431\u0435\u0441\u043F\u043B\u0430\u0442\u043D\u044B\u0439 \u0448\u0430\u0431\u043B\u043E\u043D
    Unity Pathways\n\u0418 \u0441\u043B\u0435\u043F\u0438\u043B \u0438\u0437 \u043D\u0435\u0433\u043E
    \u043D\u0435\u043A\u043E\u0435 \u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0435.\n\n\u041D\u0430\u0437\u0432\u0430\u0442\u044C
    \u044D\u0442\u043E \u0418\u0433\u0440\u043E\u0439 \u043C\u043E\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u043B\u0438\u0448\u044C \u0441 \u0442\u0440\u0443\u0434\u043E\u043C.\n\n\xAB\u0412\u043F\u0440\u043E\u0447\u0435\u043C,
    \u043F\u043E\u0434\u0443\u043C\u0430\u043B \u043E\u043D,\n\u0421\u0438\u043C\u0443\u043B\u044F\u0442\u043E\u0440\u044B
    \u043A\u0430\u043C\u043D\u044F \u0438 \u0431\u0430\u043D\u0430\u043D\u0430-\u043A\u043B\u0438\u043A\u0435\u0440\u044B\n\u041F\u0440\u0438\u043D\u043E\u0441\u044F\u0442
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044F\u043C \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u0435
    \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u044B.\n\u0417\u0430\u0447\u0435\u043C
    \u043C\u043D\u0435 \u044D\u0442\u0438 \u043B\u043E\u0436\u043D\u044B\u0435 \u0430\u043C\u0431\u0438\u0446\u0438\u0438?\n\u0417\u0430\u0447\u0435\u043C
    \u043C\u043D\u0435 \u044D\u0442\u043E\u0442 \u043C\u0430\u0441\u0448\u0442\u0430\u0431
    \u0438 \u0440\u0430\u0437\u043C\u0430\u0445?\n\u042F \u0441\u0434\u0435\u043B\u0430\u044E
    \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C \u043A\u0440\u043E\u0448\u0435\u0447\u043D\u043E\u0435\xBB.\n\n\u0412\u0440\u0435\u043C\u044F
    \u0448\u043B\u043E, \u0438 \u044D\u0442\u043E \xAB\u043C\u0430\u043B\u043E\u0435\xBB
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C.\n\u0418 \u0434\u0430\u0436\u0435
    \u043E\u043D\u043E, \u043F\u0440\u0438\u0437\u043D\u0430\u0442\u044C\u0441\u044F,
    \u0432\u044B\u0448\u043B\u043E \u0442\u0430\u043A \u0441\u0435\u0431\u0435.\n\u041D\u043E
    \u043E\u043D \u0442\u0432\u0435\u0440\u0434\u043E \u0440\u0435\u0448\u0438\u043B
    \u0432\u044B\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u044D\u0442\u043E \u0432
    \u0441\u0432\u0435\u0442.\n\u041F\u0440\u043E\u0441\u0442\u043E \u0447\u0442\u043E\u0431\u044B
    \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u0433\u0435\u0448\u0442\u0430\u043B\u044C\u0442.\n\u0417\u0430\u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0445\u043E\u0442\u044C \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u0444\u0438\u043D\u0430\u043B.\n\n\u041B\u044E\u0434\u0438
    \u0438\u0433\u0440\u0430\u043B\u0438 \u0432 \u0435\u0433\u043E \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0443\u044E
    \u043F\u043E\u0434\u0435\u043B\u043A\u0443.\n\u0418, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0434\u0443\u043C\u0430\u043B\u0438, \u0447\u0442\u043E \u0430\u0432\u0442\u043E\u0440
    \u043D\u0435 \u043C\u0430\u0441\u0442\u0435\u0440,\n\u041D\u0438\u043A\u0430\u043A\u043E\u0439
    \u043D\u0435 \u0433\u0443\u0440\u0443 \u0438 \u043D\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B.\n\u041D\u0430\u0432\u0435\u0440\u043D\u044F\u043A\u0430
    \u043E\u043D \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u0433\u0435\u043D\u0435\u0440\u0438\u0440\u043E\u0432\u0430\u043B\n\u0412\u0435\u0441\u044C
    \u043F\u0440\u043E\u0435\u043A\u0442 \u0438 \u0442\u0435\u043A\u0441\u0442\u044B
    \u0432 \u043D\u0435\u0439\u0440\u043E\u0441\u0435\u0442\u0438.\n\n\u042D\u0442\u043E
    \u043D\u0435 \u0442\u0430\u043A.\n\n\u041D\u043E \u043A\u0430\u043A \u0431\u044B
    \u043A\u0440\u0438\u0432\u043E \u043D\u0438 \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B
    \u0440\u0435\u043B\u0438\u0437,\n\u0418 \u043A\u0430\u043A \u0431\u044B \u0438\u0433\u0440\u043E\u043A\u0438
    \u0435\u0433\u043E \u043D\u0438 \u043E\u0446\u0435\u043D\u0438\u043B\u0438...\n\u041F\u0440\u043E\u0435\u043A\u0442
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0434\u0440\u0443\u0433\u0438\u0445 \u0432\u0435\u0449\u0435\u0439.\n\n\u0421\u043A\u0440\u0438\u043F\u0442\u0438\u043D\u0433,
    \u043D\u0430\u0440\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0439 \u0438 \u0433\u0435\u0439\u043C-\u0434\u0438\u0437\u0430\u0439\u043D,\n\u0428\u0435\u0439\u0434\u0435\u0440\u044B,
    \u0441\u0432\u0435\u0442, \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B
    \u0438 \u0437\u0432\u0443\u043A,\n\u041A\u0430\u043C\u0435\u0440\u044B, \u043F\u043E\u0441\u0442\u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0438\u043D\u0433,
    \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441,\n\u0410\u043D\u0438\u043C\u0430\u0446\u0438\u0438
    \u0438 \u043F\u0440\u043E\u0447\u0438\u0435 \u044D\u0444\u0444\u0435\u043A\u0442\u044B.\n\u041E\u043D
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0443\u043C\u0435\u0435\u0442
    \u0433\u043B\u0430\u0432\u043D\u043E\u0435:\n\u0414\u043E\u0432\u043E\u0434\u0438\u0442\u044C
    \u0434\u0435\u043B\u043E \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0438 \u0441\u043E\u0431\u0438\u0440\u0430\u0442\u044C
    \u043A\u0443\u0441\u043A\u0438\n\u0412 \u043E\u0434\u043D\u043E \u0435\u0434\u0438\u043D\u043E\u0435,
    \u0440\u0430\u0431\u043E\u0447\u0435\u0435 \u0446\u0435\u043B\u043E\u0435.\n\n\u041F\u0443\u0441\u0442\u044C
    \u0438 \u0442\u0430\u043A.\n\n\u041D\u043E \u0432\u0430\u0436\u043D\u043E \u043D\u0435
    \u0437\u0430\u0431\u044B\u0432\u0430\u0442\u044C \u043E\u0434\u043D\u0443 \u0434\u0435\u0442\u0430\u043B\u044C.\n\u0422\u043E
    \u0431\u044B\u043B\u0430 \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u043D\u0430\u044F
    \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F.\n\u041D\u043E \u2013
    \u044D\u0442\u043E \u043F\u043E\u0434\u043B\u0438\u043D\u043D\u0430\u044F \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C.\n\n\u0418
    \u0432\u0435\u0441\u044C \u044D\u0442\u043E\u0442 \u0442\u0435\u043A\u0441\u0442
    \u0432\u044B\u0448\u0435...\n\u041B\u0438\u0448\u044C \u0430\u043B\u043B\u0435\u0433\u043E\u0440\u0438\u044F
    \u043D\u0430 \u0447\u0430\u0441\u0442\u0443\u044E \u043E\u0448\u0438\u0431\u043A\u0443.\n\u0412\u043E\u0432\u0441\u0435
    \u043D\u0435 \u043F\u0440\u043E \u043D\u0430\u0448\u0443 \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u0443\u044E.\n\n\u0410\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
    \u0442\u043E\u0447\u043D\u043E.\n\n\nMusic by Kevin MacLeod (incompetech.com)\nLicensed
